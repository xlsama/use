{
  // theme
  "workbench.colorTheme": "Dark Modern",
  "window.systemColorTheme": "dark",

  // window
  "window.nativeTabs": true, // this is great, macOS only
  "window.openFoldersInNewWindow": "on",
  "window.title": "${rootName}",
  "window.customTitleBarVisibility": "windowed",
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.list.smoothScrolling": true,
  "workbench.editor.empty.hint": "hidden",
  "workbench.startupEditor": "none",
  "workbench.secondarySideBar.defaultVisibility": "hidden",

  // editor
  "editor.fontSize": 13,
  "editor.lineHeight": 1.55,
  "editor.fontFamily": "Maple Mono Normal NF CN",
  "editor.fontLigatures": true,
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.wordSeparators": "`~!#@%^&*()=+[{]}\\|;:'\",.<>/?",
  "editor.guides.bracketPairs": "active",
  "editor.minimap.enabled": true,
  "editor.linkedEditing": true,
  "editor.quickSuggestions": {
    "strings": "on",
  },
  "files.associations": {
    "*.css": "tailwindcss",
    "*.cjson": "jsonc",
    "*.wxss": "css",
    "*.wxs": "javascript",
  },
  "security.promptForLocalFileProtocolHandling": false,
  "editor.semanticHighlighting.enabled": true,
  "editor.accessibilitySupport": "off",
  "accessibility.signals.clear": {
    "sound": "off",
  },
  "workbench.editorAssociations": {
    "*.svg": "default",
  },
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.wrappingStrategy": "advanced",

  // format & linting
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.format.oxc": "always",
    "source.fixAll.oxc": "always"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
  },

  // languages
  "emmet.showSuggestionsAsSnippets": true,
  "emmet.includeLanguages": {
    "postcss": "css",
  },
  "js/ts.experimental.useTsgo": true,

  // search
  "search.exclude": {
    "**/.git": true,
    "**/.github": true,
    "**/.nuxt": true,
    "**/.output": true,
    "**/.pnpm": true,
    "**/.vscode": true,
    "**/.yarn": true,
    "**/bower_components": true,
    "**/dist/**": true,
    "**/logs": true,
    "**/node_modules": true,
    "**/out/**": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/tmp": true,
    "**/yarn.lock": true,
  },
  "search.smartCase": true,

  // git
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.allowNoVerifyCommit": true,
  "git.confirmNoVerifyCommit": false,
  "git.allowForcePush": true,
  "git.confirmForcePush": false,
  "git.openRepositoryInParentFolders": "always",
  "scm.workingSets.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "git.blame.statusBarItem.enabled": false,
  "git.blame.editorDecoration.enabled": true,

  // terminal
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontFamily": "Maple Mono Normal NF CN",
  "terminal.integrated.fontSize": 11,
  "terminal.integrated.fontWeight": "300",
  "terminal.integrated.fontWeightBold": "400",
  "terminal.integrated.lineHeight": 1.1,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.minimumContrastRatio": 1,
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.showExitAlert": false,
  "terminal.integrated.initialHint": false,
  "terminal.external.osxExec": "Ghostty.app",

  // explorer
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "security.workspace.trust.untrustedFiles": "open",
  "files.insertFinalNewline": true,
  "files.simpleDialog.enable": true,
  "explorer.confirmPasteNative": false,

  // extension config
  "extensions.ignoreRecommendations": true,
  "redhat.telemetry.enabled": false,
  "github.copilot.enable": {
    "plaintext": true,
    "markdown": true,
    "scminput": true,
  },
  "chat.viewSessions.orientation": "stacked",
  "workbench.productIconTheme": "icons-carbon",
  "workbench.iconTheme": "catppuccin-mocha",
}
