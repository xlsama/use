# Copy to .env and fill in. Loaded automatically by videogen CLI.

# DashScope (Alibaba Cloud Model Studio) API Key — REQUIRED
# Get one: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Region: beijing | singapore (default beijing)
VIDEOGEN_REGION=beijing

# Video model family: happyhorse | wan (default happyhorse)
# Determines which DashScope model family t2v / i2v / r2v use:
#   happyhorse → happyhorse-1.0-{t2v,i2v,r2v}
#   wan        → wan2.7-{t2v-2026-04-25,i2v-2026-04-25,r2v}
# Overridable by storyboard.provider (per-episode, written by `scene compile --provider`)
# and `videogen render --provider`. Feature differences:
#   - HappyHorse r2v does not support reference_voice or first_frame chaining
#     (render layer auto-falls back to i2v when chaining)
#   - HappyHorse does not support negative_prompt / prompt_extend
#   - HappyHorse minimum duration is 3s (Wan is 2s)
VIDEOGEN_VIDEO_PROVIDER=happyhorse

# Default model tier
VIDEOGEN_DEFAULT_RESOLUTION=720P
VIDEOGEN_DEFAULT_RATIO=16:9

# Default clip duration (seconds). Default 15 = max for t2v/i2v/r2v.
# Fewer segments → less cutting, stronger character consistency, lower API cost.
# Provider minimums differ (Wan 2s, HappyHorse 3s); provider clamps before render.
VIDEOGEN_DEFAULT_CLIP_DURATION=15

# Total-duration "budget gate" threshold (seconds). When storyboard total exceeds
# this, the director Skill must print an estimate and confirm with the user
# before burning a large API bill.
VIDEOGEN_LONG_CONFIRM_S=180

# Max concurrent submit tasks
VIDEOGEN_MAX_CONCURRENCY=4

# Poll interval (seconds)
VIDEOGEN_POLL_INTERVAL=15

# Project root (generated videos and state land here)
VIDEOGEN_PROJECTS_DIR=./projects

# === Per-clip review + auto-rewrite (Zone 3) ==================================
# After a successful render, render_shot.py automatically calls `./scripts/bl omni`
# to score the clip — this is now deterministic script logic (lib/review.py), not
# something the agent must remember to do manually.
# Score = six-axis average: logic / proportion / physics / style / cast_match / dialog_attribution.
# cast_match feeds portrait images from cast.json as --image for identity comparison;
# dialog_attribution checks whether lines are spoken by the wrong character (A's line by B).
# Six-axis average >= threshold → ACCEPT, auto-promote that version to winner (copy to clips/<id>.mp4);
# < threshold → REJECT; agent decides how to rewrite prompt / when to escalate to director.
# Threshold range 0..10, recommended 7.0. Lower = faster pass, higher = stricter quality.
VIDEOGEN_REVIEW_THRESHOLD=7.0

# Video review model (DashScope multimodal). Set to empty string "" to disable auto-review
# (render_shot.py still renders and saves, but no scoring/auto-promote — manual flow only).
# Note: default review uses `bl omni`, which picks its own omni model; this value is mainly
# an on/off switch and audit label. To force a specific review model, use SPARK_VIDEO_REVIEW_OMNI_MODEL below.
VIDEOGEN_REVIEW_MODEL=qwen3-vl-plus

# Per-review call timeout (seconds). omni can be slow on long clips; timeout → ERROR, hand back to agent.
VIDEOGEN_REVIEW_TIMEOUT_S=300

# (Optional, advanced) Force `bl omni` to use a specific multimodal model. Unset = omni default.
# Only set if your bl omni accepts --model; if bl rejects the flag, it falls back without --model.
# SPARK_VIDEO_REVIEW_OMNI_MODEL=

# Auto prompt rewrite model (DashScope text). Set to empty string "" to disable auto-rewrite;
# retries re-render the original prompt only (helps occasional model jitter).
VIDEOGEN_REWRITE_MODEL=qwen-plus

# Max renders per shot (including first). First N-1 rounds CLI auto-rewrites prompt; on Nth failure
# writes needs_director_rewrite.json and exits 3 for director Skill intervention.
VIDEOGEN_MAX_RETRY=3

# === Narration mode TTS defaults ===============================================
# /episode asks the user to choose drama (short drama) vs narration ("10-minute recap of XX").
# In narration mode, after a narration shot renders, TTS synthesizes the voice track and ffmpeg
# replaces the original audio. Mux alignment strategy (fit=narration):
# final length ∈ [TTS length, TTS length + 1s] — if video is longer, keep ≤1s silent tail;
# if narration is longer, freeze at most 1s, trim excess narration (align via duration / speech rate).
#
# Priority (per-shot > per-episode > env):
#   Shot.narrator_voice (director can override per shot)
#   > Storyboard.narrator_voice (written by scene compile --narrator-voice)
#   > VIDEOGEN_NARRATOR_VOICE (here)
#
# === TTS backend (auto-routed by model name prefix) ===
#   cosyvoice-*  → DashScope /services/audio/tts/SpeechSynthesizer
#                  · Long-series system voices (longanyang/longwan/...) or cloned voices
#                  · Native rate field (0.5-2.0), no ffmpeg atempo
#                  · ⚠️ Beijing region only; VIDEOGEN_REGION=singapore will error
#                  · Voice list https://help.aliyun.com/zh/model-studio/cosyvoice-voice-list
#   qwen*-tts*   → DashScope /services/aigc/multimodal-generation/generation
#                  · CamelCase system voices (Cherry/Ethan/...)
#                  · No native rate; ffmpeg atempo after synthesis
#                  · Voice list https://help.aliyun.com/zh/model-studio/qwen-tts#bac280ddf5a1u
VIDEOGEN_NARRATOR_TTS_MODEL=cosyvoice-v3-flash

# Default voice. Must match VIDEOGEN_NARRATOR_TTS_MODEL backend:
#   cosyvoice-*  e.g. longanyang (male, default) / longwan (female) / longxiang
#   qwen*-tts*   e.g. Cherry / Ethan / Serena / Chelsie
VIDEOGEN_NARRATOR_VOICE=longanyang

# Speech rate (0.5-2.0). Default 1.2 = 1.2× speed, duration ≈ ×1/1.2,
# reducing "narration longer than picture → final freeze waiting for audio". Set 1.0 to disable boost.
# cosyvoice uses native rate; qwen-tts uses ffmpeg atempo post-processing.
VIDEOGEN_NARRATOR_SPEECH_RATE=1.2

# Narration language hint. Auto = auto-detect; for Chinese-heavy scripts, Chinese improves quality.
# Options: Auto | Chinese | English | German | Italian | Portuguese |
#          Spanish | Japanese | Korean | French | Russian
# cosyvoice maps to language_hints (zh/en/...); Italian/Spanish not in cosyvoice list → auto-detect.
VIDEOGEN_NARRATOR_LANGUAGE=Auto

# === BGM (background music) ===================================================
# Put BGM files in projects/<id>/bgm/ (project-wide) or projects/<id>/<ep>/bgm/
# (episode-only). Supports .mp3 .wav .m4a .flac .ogg .aac. If either directory is non-empty,
# /episode asks at GATE 0.5:
#   1. Usage mode (off / global / scene)
#   2. Whether to forbid the model from generating its own BGM (default on — avoids double music)
# Both options go into storyboard.bgm; render adds "no score" directives to prompt/negative_prompt;
# stitch ffmpeg amix mixes selected tracks under dialogue/narration.
#
# Default volume only; per-episode override via `bgm configure --volume`.
# VIDEOGEN_BGM_DEFAULT_VOLUME=0.25
